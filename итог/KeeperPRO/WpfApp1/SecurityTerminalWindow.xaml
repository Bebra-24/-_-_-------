<Window x:Class="WpfApp1.SecurityTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Терминал сотрудника охраны" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Терминал сотрудника охраны" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="UserInfoText" Text="" FontSize="12" Foreground="#b0bec5"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#ECEFF1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="DateFilterPicker" Width="120" Height="30" Margin="5" 
                            SelectedDateChanged="DateFilter_Changed"/>
                <Button Content="Очистить" Width="80" Height="30" Margin="5" 
                        Background="#607D8B" Foreground="White" Click="ClearFilters_Click"/>
                <Button x:Name="RefreshBtn" Content="Обновить" Width="80" Height="30" Margin="5" 
                        Background="#2196F3" Foreground="White" Click="RefreshBtn_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="RequestsGrid" AutoGenerateColumns="True" IsReadOnly="True"
                      AlternatingRowBackground="#F5F5F5" FontSize="13" 
                      SelectionChanged="RequestsGrid_SelectionChanged"/>
        </Border>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="OpenDepartmentBtn" Content="Терминал подразделения" Width="180" Height="35" Margin="5" 
                    Background="#FF9800" Foreground="White" Click="OpenDepartmentBtn_Click"/>
            <Button x:Name="LogoutBtn" Content="Выйти" Width="100" Height="35" Margin="5" 
                    Background="#F44336" Foreground="White" Click="LogoutBtn_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="4" Text="Готов" Foreground="Green" HorizontalAlignment="Center" Margin="5"/>
    </Grid>
</Window>