<Window x:Class="WpfApp1.SecurityRequestWorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Работа с заявкой" Height="500" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" Text="Информация о заявке" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Информация о заявке" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock x:Name="InfoText" Text="" TextWrapping="Wrap" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Разрешение доступа" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Button x:Name="AllowAccessBtn" Content="РАЗРЕШИТЬ ДОСТУП" Height="50" 
                                Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold"
                                Click="AllowAccessBtn_Click"/>
                        <TextBlock x:Name="AccessMessageText" Text="" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Фиксация убытия" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Button x:Name="ExitTimeBtn" Content="ЗАФИКСИРОВАТЬ УБЫТИЕ" Height="40" 
                                Background="#FF9800" Foreground="White" FontSize="13" FontWeight="Bold"
                                Click="ExitTimeBtn_Click"/>
                        <TextBlock x:Name="ExitTimeText" Text="" Margin="0,10,0,0" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="Закрыть" Width="100" Height="40" Margin="5" 
                    Background="#2196F3" Foreground="White" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>