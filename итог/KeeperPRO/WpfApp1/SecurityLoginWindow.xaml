<Window x:Class="WpfApp1.SecurityLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Вход для сотрудника охраны" Height="350" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="MAX.Х.ПРО - Вход для охраны" FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Text="Код сотрудника:" Margin="0,5" Foreground="#555555" FontSize="14"/>
        <PasswordBox x:Name="CodeBox" Grid.Row="2" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Вход" Width="100" Height="40" Margin="5" 
                    Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold"
                    Click="LoginBtn_Click"/>
            <Button Content="Отмена" Width="100" Height="40" Margin="5" 
                    Background="#F44336" Foreground="White" FontSize="14" FontWeight="Bold"
                    Click="CancelBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="4" Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,10">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="Введите код сотрудника" 
                           Foreground="#C62828" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" FontWeight="Bold"/>
                <TextBlock x:Name="DebugText" Text="" Foreground="#455A64" 
                           HorizontalAlignment="Center" FontSize="11" Margin="0,5,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="ConnectionStatus" Grid.Row="5" Text="🔄 Проверка подключения..." 
                   Foreground="Gray" HorizontalAlignment="Center" FontSize="11" Margin="0,10"/>
    </Grid>
</Window>