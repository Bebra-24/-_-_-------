<Window x:Class="KeeperPRO.MyRequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Мои заявки" Height="500" Width="850"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock x:Name="UserInfoText" Text="Загрузка..." FontSize="14" Foreground="#333333"/>
        </Border>

        <!-- Фильтры -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10" Height="35">
            <ComboBox x:Name="StatusFilterCombo" Width="150" Margin="5" SelectionChanged="StatusFilterCombo_SelectionChanged" BorderBrush="#E0E0E0">
                <ComboBoxItem Content="Все заявки" IsSelected="True"/>
                <ComboBoxItem Content="На проверке"/>
                <ComboBoxItem Content="Одобрена"/>
                <ComboBoxItem Content="Не одобрена"/>
            </ComboBox>
            <TextBox x:Name="SearchBox" Width="200" Margin="5" TextChanged="SearchBox_TextChanged" BorderBrush="#E0E0E0"/>
            <Button x:Name="ClearFilterBtn" Content="Очистить" Width="80" Margin="5" Click="ClearFilterBtn_Click"
                    Background="#2196F3" Foreground="White"/>
            <Button x:Name="RefreshBtn" Content="Обновить" Width="80" Margin="5" Click="RefreshBtn_Click"
                    Background="#4CAF50" Foreground="White"/>
        </StackPanel>

        <!-- Таблица -->
        <DataGrid x:Name="RequestsGrid" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" FontSize="13" BorderBrush="#E0E0E0"/>

        <!-- Счётчик -->
        <TextBlock x:Name="CountText" Grid.Row="3" Margin="5" HorizontalAlignment="Center" FontSize="12" Foreground="#555555"/>
    </Grid>
</Window>