<Window x:Class="KeeperPRO.RequestDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Детали заявки" Height="600" Width="750"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" Text="Информация о заявке" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Основная информация -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Информация о заявке" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип:" Margin="5" Foreground="#555555"/>
                            <TextBlock x:Name="TypeText" Grid.Column="1" Margin="5"/>

                            <TextBlock Grid.Column="0" Text="Посетитель:" Margin="5" Foreground="#555555" Grid.Row="1"/>
                            <TextBlock x:Name="VisitorText" Grid.Column="1" Margin="5" Grid.Row="1" TextWrapping="Wrap"/>

                            <TextBlock Grid.Column="0" Text="Дата:" Margin="5" Foreground="#555555" Grid.Row="2"/>
                            <TextBlock x:Name="DateText" Grid.Column="1" Margin="5" Grid.Row="2"/>

                            <TextBlock Grid.Column="0" Text="Цель:" Margin="5" Foreground="#555555" Grid.Row="3"/>
                            <TextBlock x:Name="PurposeText" Grid.Column="1" Margin="5" Grid.Row="3" TextWrapping="Wrap"/>

                            <TextBlock Grid.Column="0" Text="Статус:" Margin="5" Foreground="#555555" Grid.Row="4"/>
                            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="5" Grid.Row="4" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Список участников (для групповой заявки) -->
                <Border x:Name="MembersBorder" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Список участников группы" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid x:Name="MembersGrid" AutoGenerateColumns="True" IsReadOnly="True" Height="200"/>
                    </StackPanel>
                </Border>

                <!-- Проверка черного списка -->
                <Border x:Name="BlacklistBorder" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Проверка черного списка" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock x:Name="BlacklistStatusText" Text="Проверка..." FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Причина отказа -->
                <Border x:Name="ReasonBorder" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FFEBEE" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Причина отказа" FontWeight="Bold" Foreground="#C62828"/>
                        <TextBlock x:Name="ReasonText" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="ApproveBtn" Content="Одобрить" Width="100" Height="40" Margin="5" 
                    Background="#4CAF50" Foreground="White" Click="ApproveBtn_Click"/>
            <Button x:Name="RejectBtn" Content="Отклонить" Width="100" Height="40" Margin="5" 
                    Background="#F44336" Foreground="White" Click="RejectBtn_Click"/>
            <Button x:Name="CloseBtn" Content="Закрыть" Width="100" Height="40" Margin="5" 
                    Background="#2196F3" Foreground="White" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>