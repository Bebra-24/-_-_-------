<Window x:Class="KeeperPRO.EmployeeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Вход для сотрудника" Height="280" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вход для сотрудника" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Код сотрудника:" Margin="0,5" Foreground="#555555"/>
        <PasswordBox x:Name="CodeBox" Grid.Row="2" Height="35" FontSize="14" Margin="0,0,0,20" Padding="5"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Вход" Width="100" Height="40" Margin="5" Background="#2196F3" Foreground="White" Click="LoginBtn_Click"/>
            <Button Content="Отмена" Width="100" Height="40" Margin="5" Background="#F44336" Foreground="White" Click="CancelBtn_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="4" Foreground="Red" HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>