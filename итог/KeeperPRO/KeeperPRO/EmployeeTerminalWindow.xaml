<Window x:Class="KeeperPRO.EmployeeTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Терминал сотрудника общего отдела" 
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Терминал сотрудника общего отдела" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="UserInfoText" Text="" FontSize="12" Foreground="#b0bec5"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#ECEFF1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Тип заявки:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="TypeFilterCombo" Grid.Column="1" Height="30" Margin="5" 
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="личная"/>
                    <ComboBoxItem Content="групповая"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Подразделение:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="DepartmentFilterCombo" Grid.Column="3" Height="30" Margin="5" 
                          SelectionChanged="Filter_Changed"/>

                <TextBlock Grid.Column="4" Text="Статус:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="StatusFilterCombo" Grid.Column="5" Height="30" Margin="5" 
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="на проверке"/>
                    <ComboBoxItem Content="одобрена"/>
                    <ComboBoxItem Content="не одобрена"/>
                </ComboBox>

                <Button Grid.Column="6" Content="Очистить" Width="80" Height="30" Margin="5" 
                        Background="#607D8B" Foreground="White" Click="ResetFiltersBtn_Click"/>
            </Grid>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="RequestsGrid" AutoGenerateColumns="True" IsReadOnly="True"
                      AlternatingRowBackground="#F5F5F5" FontSize="13" 
                      SelectionChanged="RequestsGrid_SelectionChanged"/>
        </Border>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="ReportsBtn" Content="Отчёты" Width="100" Height="35" Margin="5" 
                    Background="#9C27B0" Foreground="White" Click="ReportsBtn_Click"/>
            <Button x:Name="LogoutBtn" Content="Выйти" Width="100" Height="35" Margin="5" 
                    Background="#F44336" Foreground="White" Click="LogoutBtn_Click"/>
        </StackPanel>

        <TextBlock x:Name="CountText" Grid.Row="4" Text="Всего заявок: 0" Foreground="Green" HorizontalAlignment="Center" Margin="5"/>
    </Grid>
</Window>