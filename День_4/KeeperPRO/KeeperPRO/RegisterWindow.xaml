<Window x:Class="KeeperPRO.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Регистрация" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock Text="MAX.Х.ПРО" FontSize="22" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Text="Email (будет использован как логин)" Margin="0,5" FontSize="14" Foreground="#555555"/>
        <TextBox x:Name="EmailBox" Grid.Row="2" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1"/>

        <TextBlock Grid.Row="3" Text="Пароль" Margin="0,5" FontSize="14" Foreground="#555555"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Height="35" FontSize="14" Margin="0,0,0,10" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1"/>

        <Border Grid.Row="5" Background="#FFF3CD" CornerRadius="5" Padding="8" Margin="0,10">
            <TextBlock Text="Требования: мин. 8 символов, заглавная + строчная буквы, цифра, спецсимвол" 
                       FontSize="11" Foreground="#856404" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="RegisterSQLBtn" Content="SQL" Width="80" Height="35" Margin="5" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold" Click="RegisterSQLBtn_Click"/>
            <Button x:Name="RegisterProcBtn" Content="Хранимая процедура" Width="140" Height="35" Margin="5" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="RegisterProcBtn_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="7" Foreground="#C62828" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,10"/>
    </Grid>
</Window>