<Window x:Class="KeeperPRO.GroupRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Групповая заявка" Height="750" Width="850"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock Text="Групповая заявка на посещение" FontSize="18" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о пропуске -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Информация о пропуске" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,10"/>
                        <TextBlock Text="Дата начала (от завтра до +15 дней)" Margin="0,5" Foreground="#555555"/>
                        <DatePicker x:Name="StartDatePicker" Margin="0,5,0,15" Height="32" BorderBrush="#E0E0E0"/>
                        <TextBlock Text="Дата окончания" Margin="0,5" Foreground="#555555"/>
                        <DatePicker x:Name="EndDatePicker" Margin="0,5,0,15" Height="32" BorderBrush="#E0E0E0"/>
                        <TextBlock Text="Цель посещения" Margin="0,5" Foreground="#555555"/>
                        <TextBox x:Name="PurposeBox" Height="60" TextWrapping="Wrap" Margin="0,5,0,15" BorderBrush="#E0E0E0" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <!-- Принимающая сторона -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Принимающая сторона" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,10"/>
                        <TextBlock Text="Подразделение" Margin="0,5" Foreground="#555555"/>
                        <ComboBox x:Name="DepartmentCombo" Margin="0,5,0,15" Height="32" 
                                  DisplayMemberPath="название" SelectedValuePath="код_подразделения"
                                  SelectionChanged="DepartmentCombo_SelectionChanged" BorderBrush="#E0E0E0"/>
                        <TextBlock Text="Сотрудник" Margin="0,5" Foreground="#555555"/>
                        <ComboBox x:Name="EmployeeCombo" Margin="0,5,0,15" Height="32" 
                                  DisplayMemberPath="фио" SelectedValuePath="код_сотрудника" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Border>

                <!-- Список посетителей -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Список посетителей (минимум 5 человек)" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="DownloadTemplateBtn" Content="Скачать шаблон" Width="150" Height="35" 
                                    Margin="0,0,10,0" Background="#2196F3" Foreground="White" Click="DownloadTemplateBtn_Click"/>
                            <Button x:Name="UploadListBtn" Content="Загрузить список" Width="150" Height="35" 
                                    Background="#4CAF50" Foreground="White" Click="UploadListBtn_Click"/>
                        </StackPanel>

                        <TextBlock Text="Или добавьте участников вручную:" Margin="0,10,0,5" Foreground="#555555"/>

                        <DataGrid x:Name="MembersGrid" AutoGenerateColumns="False" Height="250" Margin="0,5" 
                                  CanUserAddRows="False" BorderBrush="#E0E0E0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Номер}" Width="50"/>
                                <DataGridTextColumn Header="Фамилия" Binding="{Binding Фамилия}" Width="100"/>
                                <DataGridTextColumn Header="Имя" Binding="{Binding Имя}" Width="100"/>
                                <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="110"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                                <DataGridTextColumn Header="Дата рождения" Binding="{Binding ДатаРождения, StringFormat='dd.MM.yyyy'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                            <Button x:Name="AddMemberBtn" Content="Добавить участника" Width="160" Height="35" 
                                    Margin="5" Background="#2196F3" Foreground="White" Click="AddMemberBtn_Click"/>
                            <Button x:Name="RemoveMemberBtn" Content="Удалить участника" Width="160" Height="35" 
                                    Margin="5" Background="#F44336" Foreground="White" Click="RemoveMemberBtn_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Прикрепляемые документы -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Прикрепляемые документы" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,10"/>
                        <Button x:Name="UploadPassportBtn" Content="Загрузить скан паспорта (PDF)" 
                                Height="40" Background="#FF9800" Foreground="White" Click="UploadPassportBtn_Click"/>
                        <TextBlock x:Name="PassportFileText" Text="Файл не выбран" Margin="0,5" FontSize="11" Foreground="#888888"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="SubmitBtn" Content="Отправить заявку" Width="150" Height="45" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="SubmitBtn_Click" Margin="10"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="120" Height="45" 
                    Background="#F44336" Foreground="White" FontWeight="Bold" FontSize="14"
                    Click="CancelBtn_Click" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>