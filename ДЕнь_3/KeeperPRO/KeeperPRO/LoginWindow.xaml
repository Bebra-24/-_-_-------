<Window x:Class="KeeperPRO.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Авторизация" Height="420" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock Text="MAX.Х.ПРО" FontSize="22" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Text="Логин (Email)" Margin="0,5" FontSize="14" Foreground="#555555"/>
        <TextBox x:Name="LoginBox" Grid.Row="2" Height="35" FontSize="14" Margin="0,0,0,15" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1"/>

        <TextBlock Grid.Row="3" Text="Пароль" Margin="0,5" FontSize="14" Foreground="#555555"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Height="35" FontSize="14" Margin="0,0,0,20" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1"/>

        <TextBlock Grid.Row="5" Text="Выберите способ авторизации:" Margin="0,5" FontSize="12" Foreground="#888888"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="LoginSQLBtn" Content="SQL" Width="80" Height="35" Margin="5" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold" Click="LoginSQLBtn_Click"/>
            <Button x:Name="LoginProcBtn" Content="Хранимая процедура" Width="140" Height="35" Margin="5" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="LoginProcBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="7" Background="#FFEBEE" CornerRadius="5" Padding="10" Margin="0,10">
            <StackPanel>
                <TextBlock x:Name="StatusText" Foreground="#C62828" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" FontWeight="Bold"/>
                <TextBlock x:Name="DebugText" Foreground="#455A64" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" FontSize="11" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>