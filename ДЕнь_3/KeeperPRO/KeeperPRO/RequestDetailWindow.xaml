<Window x:Class="KeeperPRO.RequestDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAX.Х.ПРО - Детали заявки" Height="650" Width="750"
        WindowStartupLocation="CenterOwner"
        Icon="Icon/icon2.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1a237e" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" Text="Информация о заявке" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Статус проверки черного списка -->
                <Border x:Name="BlacklistBorder" CornerRadius="8" Padding="15" Margin="0,5">
                    <TextBlock x:Name="BlacklistStatusText" Text="Проверка черного списка..." FontWeight="Bold"/>
                </Border>

                <!-- Информация о заявке -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Информация о заявке" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип заявки:" Margin="5" Foreground="#555555"/>
                            <TextBlock x:Name="RequestTypeText" Grid.Column="1" Margin="5"/>

                            <TextBlock Grid.Column="0" Text="Статус:" Margin="5" Foreground="#555555" Grid.Row="1"/>
                            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="5" Grid.Row="1"/>

                            <TextBlock Grid.Column="0" Text="Дата начала:" Margin="5" Foreground="#555555" Grid.Row="2"/>
                            <TextBlock x:Name="StartDateText" Grid.Column="1" Margin="5" Grid.Row="2"/>

                            <TextBlock Grid.Column="0" Text="Дата окончания:" Margin="5" Foreground="#555555" Grid.Row="3"/>
                            <TextBlock x:Name="EndDateText" Grid.Column="1" Margin="5" Grid.Row="3"/>

                            <TextBlock Grid.Column="0" Text="Цель:" Margin="5" Foreground="#555555" Grid.Row="4"/>
                            <TextBlock x:Name="PurposeText" Grid.Column="1" Margin="5" Grid.Row="4" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Данные посетителя -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Данные посетителя" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ФИО:" Margin="5" Foreground="#555555"/>
                            <TextBlock x:Name="FioText" Grid.Column="1" Margin="5"/>

                            <TextBlock Grid.Column="0" Text="Паспорт:" Margin="5" Foreground="#555555" Grid.Row="1"/>
                            <TextBlock x:Name="PassportText" Grid.Column="1" Margin="5" Grid.Row="1"/>

                            <TextBlock Grid.Column="0" Text="Email:" Margin="5" Foreground="#555555" Grid.Row="2"/>
                            <TextBlock x:Name="EmailText" Grid.Column="1" Margin="5" Grid.Row="2"/>

                            <TextBlock Grid.Column="0" Text="Телефон:" Margin="5" Foreground="#555555" Grid.Row="3"/>
                            <TextBlock x:Name="PhoneText" Grid.Column="1" Margin="5" Grid.Row="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Список участников (для групповой заявки) -->
                <Border x:Name="MembersBorder" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FAFAFA" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Список участников группы" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid x:Name="MembersGrid" AutoGenerateColumns="True" IsReadOnly="True" Height="200"/>
                    </StackPanel>
                </Border>

                <!-- Причина отказа (если есть) -->
                <Border x:Name="ReasonBorder" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5" Background="#FFEBEE" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Причина отказа" FontWeight="Bold" Foreground="#C62828"/>
                        <TextBlock x:Name="ReasonText" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя панель с кнопками -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="ApproveBtn" Content="Одобрить" Width="100" Height="40" Margin="5"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="ApproveBtn_Click" Visibility="Collapsed"/>
            <Button x:Name="RejectBtn" Content="Отклонить" Width="100" Height="40" Margin="5"
                    Background="#F44336" Foreground="White" FontWeight="Bold" Click="RejectBtn_Click" Visibility="Collapsed"/>
            <Button x:Name="CloseBtn" Content="Закрыть" Width="100" Height="40" Margin="5"
                    Background="#2196F3" Foreground="White" FontWeight="Bold" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>