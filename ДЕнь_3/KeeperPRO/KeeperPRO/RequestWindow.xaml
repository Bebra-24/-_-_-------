<Window x:Class="KeeperPRO.RequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка" Height="600" Width="650"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text=" Оформление заявки на посещение" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Border BorderBrush="#b0bec5" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text=" Информация о посещении" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="Дата посещения * (от завтра до +15 дней)" Margin="0,5"/>
                        <DatePicker x:Name="VisitDatePicker" Margin="0,5,0,15" Height="30"/>
                        <TextBlock Text="Цель посещения *" Margin="0,5"/>
                        <TextBox x:Name="PurposeBox" Height="60" TextWrapping="Wrap" Margin="0,5,0,15"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#b0bec5" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text=" Данные посетителя" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия *" Margin="5"/>
                            <TextBox x:Name="LastNameBox" Grid.Row="1" Grid.Column="0" Margin="5" Height="30"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Имя *" Margin="5"/>
                            <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Email *" Margin="5"/>
                            <TextBox x:Name="EmailBox" Grid.Row="3" Grid.Column="0" Margin="5" Height="30"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Телефон" Margin="5"/>
                            <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#b0bec5" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text=" Паспортные данные" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Серия (4 цифры) *" Margin="5"/>
                            <TextBox x:Name="PassportSeriesBox" Grid.Column="0" Grid.Row="1" MaxLength="4" Margin="5" Height="30"/>
                            <TextBlock Grid.Column="1" Text="Номер (6 цифр) *" Margin="5"/>
                            <TextBox x:Name="PassportNumberBox" Grid.Column="1" Grid.Row="1" MaxLength="6" Margin="5" Height="30"/>
                        </Grid>
                        <TextBlock Text="Дата рождения * (не моложе 16 лет)" Margin="5,10,5,5"/>
                        <DatePicker x:Name="BirthDatePicker" Margin="5,0,5,0" Height="30"/>
                        <TextBlock Text="Примечание *" Margin="5,10,5,5"/>
                        <TextBox x:Name="NoteBox" Height="50" TextWrapping="Wrap" Margin="5,0,5,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="SubmitBtn" Content="✓ Отправить заявку" Width="140" Height="40" 
                    Background="#66bb6a" Foreground="White" FontWeight="Bold" Click="SubmitBtn_Click" Margin="5"/>
            <Button x:Name="CancelBtn" Content="✗ Отмена" Width="100" Height="40" 
                    Background="#ef5350" Foreground="White" FontWeight="Bold" Click="CancelBtn_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>